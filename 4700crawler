# Level 4: cookie jar. Save every Set-Cookie the server sends into a dict,
# and send them back as a Cookie header on each request.
# this is the thing that later let me stay logged in.

import argparse
import socket
import ssl

DEFAULT_SERVER = "fakebook.khoury.northeastern.edu"
DEFAULT_PORT = 443

class Crawler:
    def __init__(self, args):
        self.server = args.server
        self.port = args.port
        self.username = args.username
        self.password = args.password

        # keep for later levels: reuse one socket + hold leftover bytes
        self.socket = None
        self.recv_buffer = b""
        # my cookie jar
        self.cookies = {}

    def store_cookie(self, cookie_line):
        """
        Take one Set-Cookie value like "csrftoken=abc; Path=/; Secure"
        and save only the name=value part into my jar. The rest (Path,
        Expires, Secure ...) are attributes, not the cookie itself,
        so I drop them.
        """
        # the real cookie is before the first ";", attributes come after
        first = cookie_line.split(";")[0]
        if "=" in first:
            name, value = first.split("=", 1)
            self.cookies[name.strip()] = value.strip()

    def cookie_header(self):
        """
        Build the Cookie: request header from my jar,
        like "Cookie: name1=value1; name2=value2\r\n".
        if the jar is empty so I add nothing.
        """
        if not self.cookies:
            return ""
        pairs = []
        for name in self.cookies:
            pairs.append(name + "=" + self.cookies[name])
        return "Cookie: " + "; ".join(pairs) + "\r\n"

    def dechunk(self, body):
        """
        Decode a chunked body that I ALREADY have in full (I read until
        the server closed, so every byte is here). The format is: a hex
        size line, then that many data bytes, then \r\n, again and again,
        until a size of 0. Join the data pieces = the real html. Because
        the body is complete, I never need to recv() in here.
        """
        out = b""
        buf = body
        while True:
            # the size line end at the first \r\n
            line, sep, buf = buf.partition(b"\r\n")
            # size line is hex; it may have ";extra" after it, so cut at ";" first
            size = int(line.split(b";")[0], 16)
            if size == 0:
                # size 0 means I reach the end of the body
                break
            # take that many real bytes, then skip the \r\n after them
            out = out + buf[:size]
            buf = buf[size + 2:]
        return out

    def parse_response(self, data):
        """
        Cut one raw response into status code, headers dict, and body.
        Set-Cookie is special: a response may send SEVERAL of them,
        so instead of putting it in the dict , I send each Set-Cookie to my cookie jar.
        if the body is chunked, decode it too.
        """
        # the blank line "\r\n\r\n" split the head from the body
        head, sep, body = data.partition(b"\r\n\r\n")

        # head is bytes, turn it to text and cut into lines
        head_text = head.decode("ascii", errors="replace")
        lines = head_text.split("\r\n")

        # first line is like "HTTP/1.1 302 Found", the middle piece is the code
        status_line = lines[0]
        parts = status_line.split(" ")
        status = int(parts[1])

        # the other lines are headers, each one look like "Name: Value"
        headers = {}
        for line in lines[1:]:
            if ": " in line:
                name, value = line.split(": ", 1)
                name = name.lower()
                if name == "set-cookie":
                    # one response can send many Set-Cookie lines, store each
                    self.store_cookie(value)
                else:
                    # a normal header, put it in the dict
                    headers[name] = value

        # if the server sent the body in chunks, turn it back to real html
        if headers.get("transfer-encoding", "").lower() == "chunked":
            body = self.dechunk(body)

        return status, headers, body

    def run(self):
        """
        Level 4: GET the login page . it should reply 200 with a Set-Cookie,
        and my cookie jar should catch it. I also attach my Cookie header
        (empty on this first request, but the machinery is in place).
        """
        # GET the login page this time (Level 3's 302 pointed here)
        request = "GET /accounts/login/?next=/fakebook/ HTTP/1.1\r\n"
        request += "Host: " + self.server + "\r\n"
        request += self.cookie_header()   # send my cookies (empty for now)
        request += "Connection: close\r\n"
        request += "\r\n"

        # print what I send, just for me to check (take out later)
        print("Request to %s:%d" % (self.server, self.port))
        print(request)

        # make a TCP socket and wrap it in TLS, same as Level 1
        mysocket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        context = ssl.create_default_context()
        mysocket = context.wrap_socket(mysocket, server_hostname=self.server)
        mysocket.connect((self.server, self.port))
        mysocket.send(request.encode('ascii'))

        # read all the bytes until the server close, same as Level 1
        data = b""
        while True:
            part = mysocket.recv(4096)
            if len(part) == 0:
                break
            data = data + part

        # parse_response now also store any Set-Cookie into my jar
        status, headers, body = self.parse_response(data)

        print("Status code: %d" % status)
        if "location" in headers:
            print("Location: %s" % headers["location"])
        print("Body length: %d bytes" % len(body))
        # show the jar, so I can see Set-Cookie really got stored
        print("Cookies stored: %s" % self.cookies)

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='crawl Fakebook')
    parser.add_argument('-s', dest="server", type=str, default=DEFAULT_SERVER, help="The server to crawl")
    parser.add_argument('-p', dest="port", type=int, default=DEFAULT_PORT, help="The port to use")
    parser.add_argument('username', type=str, help="The username to use")
    parser.add_argument('password', type=str, help="The password to use")
    args = parser.parse_args()
    sender = Crawler(args)
    sender.run()
