# Project 5 - Web Crawler
# Level 8: the BFS crawl loop. Keep a frontier (queue of paths to visit)
# and a visited set (so we never visit a path twice = watch for loops).
# For each page: fetch, parse, collect flags, queue new /fakebook/
# links. Stop at 5 flags. Skipping non-/fakebook/ paths avoids logout.

import argparse
import socket
import ssl
from html.parser import HTMLParser
from urllib.parse import urlencode, urljoin, urlparse
from collections import deque


DEFAULT_SERVER = "fakebook.khoury.northeastern.edu"
DEFAULT_PORT = 443


class PageParser(HTMLParser):
    """
    Walk a fakebook page and collect two things the crawler need:
    - self.links: every <a href="..."> value (pages to maybe follow)
    - self.flags: every secret flag. the spec say a flag look like
      <h3 class='secret_flag' ...>FLAG: 64-chars</h3>, so when I am
      inside such an h3 I read its text and keep the 64 chars.
    """
    def __init__(self):
        super().__init__()
        self.links = []
        self.flags = []
        self.in_flag = False        # True while I am inside a secret_flag h3

    def handle_starttag(self, tag, attrs):
        # attrs is a list of (name, value) pairs for this one tag
        attr = dict(attrs)
        # an <a href="..."> is a hyperlink (slide 7); remember its target
        if tag == "a":
            href = attr.get("href")
            if href:
                self.links.append(href)
        # a secret flag live in <h3 class='secret_flag'>; flip a switch on
        if tag == "h3" and "secret_flag" in (attr.get("class") or ""):
            self.in_flag = True

    def handle_endtag(self, tag):
        # the flag text end when its h3 close
        if tag == "h3":
            self.in_flag = False

    def handle_data(self, data):
        # the text inside a secret_flag h3 is "FLAG: <64 chars>"; I keep
        # only the 64 chars and drop the "FLAG: " label in front
        if self.in_flag:
            text = data.strip()
            if text.startswith("FLAG: "):
                self.flags.append(text[len("FLAG: "):])


class TokenFinder(HTMLParser):
    """
    A HTML parser that walks the login form and grabs the value of the hidden field
    <input name="csrfmiddlewaretoken" value="...">.
    """
    def __init__(self):
        super().__init__()
        self.token = None

    def handle_starttag(self, tag, attrs):
        # attrs is a list of (name, value) pairs for this one tag
        if tag == "input":
            attr = dict(attrs)
            if attr.get("name") == "csrfmiddlewaretoken":
                self.token = attr.get("value")

class Crawler:
    def __init__(self, args):
        self.server = args.server
        self.port = args.port
        self.username = args.username
        self.password = args.password

        # keep for later levels: reuse one socket + hold leftover bytes
        self.socket = None
        self.recv_buffer = b""
        # my cookie jar
        self.cookies = {}

    def store_cookie(self, cookie_line):
        """
        Take one Set-Cookie value like "csrftoken=abc; Path=/; Secure"
        and save only the name=value part into my jar. The rest (Path,
        Expires, Secure ...) are attributes, not the cookie itself,
        so I drop them.
        """
        # the real cookie is before the first ";", attributes come after
        first = cookie_line.split(";")[0]
        if "=" in first:
            name, value = first.split("=", 1)
            self.cookies[name.strip()] = value.strip()

    def cookie_header(self):
        """
        Build the Cookie: request header from my jar,
        like "Cookie: name1=value1; name2=value2\r\n".
        if the jar is empty so I add nothing.
        """
        if not self.cookies:
            return ""
        pairs = []
        for name in self.cookies:
            pairs.append(name + "=" + self.cookies[name])
        return "Cookie: " + "; ".join(pairs) + "\r\n"

    def dechunk(self, body):
        """
        Decode a chunked body that I ALREADY have in full (I read until
        the server closed, so every byte is here). The format is: a hex
        size line, then that many data bytes, then \r\n, again and again,
        until a size of 0. Join the data pieces = the real html. Because
        the body is complete, I never need to recv() in here.
        """
        out = b""
        buf = body
        while True:
            # the size line end at the first \r\n
            line, sep, buf = buf.partition(b"\r\n")
            # size line is hex; it may have ";extra" after it, so cut at ";" first
            size = int(line.split(b";")[0], 16)
            if size == 0:
                # size 0 means I reach the end of the body
                break
            # take that many real bytes, then skip the \r\n after them
            out = out + buf[:size]
            buf = buf[size + 2:]
        return out

    def parse_response(self, data):
        """
        Cut one raw response into status code, headers dict, and body.
        Set-Cookie is special: a response may send SEVERAL of them,
        so instead of putting it in the dict , I send each Set-Cookie to my cookie jar.
        if the body is chunked, decode it too.
        """
        # the blank line "\r\n\r\n" split the head from the body
        head, sep, body = data.partition(b"\r\n\r\n")

        # head is bytes, turn it to text and cut into lines
        head_text = head.decode("ascii", errors="replace")
        lines = head_text.split("\r\n")

        # first line is like "HTTP/1.1 302 Found", the middle piece is the code
        status_line = lines[0]
        parts = status_line.split(" ")
        status = int(parts[1])

        # the other lines are headers, each one look like "Name: Value"
        headers = {}
        for line in lines[1:]:
            if ": " in line:
                name, value = line.split(": ", 1)
                name = name.lower()
                if name == "set-cookie":
                    # one response can send many Set-Cookie lines, store each
                    self.store_cookie(value)
                else:
                    # a normal header, put it in the dict
                    headers[name] = value

        # if the server sent the body in chunks, turn it back to real html
        if headers.get("transfer-encoding", "").lower() == "chunked":
            body = self.dechunk(body)

        return status, headers, body

    def find_csrf_token(self, body):
        """
        Run TokenFinder over the form html
        and return the csrfmiddlewaretoken string.
        """
        finder = TokenFinder()
        finder.feed(body.decode("utf-8", errors="replace"))
        return finder.token

    def build_get(self, path):
        """
        Build a GET request as bytes: request line + Host + my cookies
        + Connection: close + blank line. reused by login and later.
        """
        req = "GET " + path + " HTTP/1.1\r\n"
        req += "Host: " + self.server + "\r\n"
        req += self.cookie_header()
        req += "Connection: close\r\n"
        req += "\r\n"
        return req.encode("ascii")

    def build_post(self, path, fields, referer):
        """
        Build a POST request as bytes. the form fields become the body,
        I tell the server Content-Length, and send Referer + Origin + my csrftoken cookie
        so the CSRF check pass.
        """
        body = urlencode(fields)
        req = "POST " + path + " HTTP/1.1\r\n"
        req += "Host: " + self.server + "\r\n"
        req += self.cookie_header()
        req += "Referer: " + referer + "\r\n"
        req += "Content-Type: application/x-www-form-urlencoded\r\n"
        req += "Content-Length: " + str(len(body)) + "\r\n"
        req += "Connection: close\r\n"
        req += "\r\n"
        req += body
        return req.encode("ascii")

    def send(self, request_bytes):
        """
        Open one TLS connection, send the request, read the whole
        response until the server close, parse it.
        Returns (status, headers, body). pulled out so login can call it for
        both the GET and the POST (and crawling later).
        """
        mysocket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        context = ssl.create_default_context()
        mysocket = context.wrap_socket(mysocket, server_hostname=self.server)
        mysocket.connect((self.server, self.port))
        mysocket.send(request_bytes)
        data = b""
        while True:
            part = mysocket.recv(4096)
            if len(part) == 0:
                break
            data = data + part
        return self.parse_response(data)

    def fetch(self, path):
        """
        GET a path and handle the status code the way the spec wants:
          200 -> return the body (good, ready to parse)
          302 -> follow the Location header (a redirect) and try again
          503 -> server is busy, retry the same path
          403 / 404 (or anything else) -> give up, return None
        We loop because 302 and 503 both mean "try again".
        """
        while True:
            status, headers, body = self.send(self.build_get(path))
            if status == 200:
                return body
            if status == 302:
                # the new place is in Location; it may be relative, so
                # urljoin it onto our current url, then keep just the path
                location = headers.get("location", "")
                full = urljoin("https://" + self.server + path, location)
                parsed = urlparse(full)
                path = parsed.path
                if parsed.query:
                    path = path + "?" + parsed.query
                continue
            if status == 503:
                # server said it is busy; just try the same path again
                continue
            # 403, 404, or any other code: this url is a dead end, drop it
            return None

    def parse_page(self, body, base_path):
        """
        Parse one page's html. Return (links, flags):
        - links: same-domain paths pulled from <a href>, ready to crawl
        - flags: any secret flags found on this page
        urljoin turn a relative href into a full url against the page I
        am on; I keep only urls whose domain is my server (spec: only
        crawl the target domain) and store them as paths.
        """
        parser = PageParser()
        parser.feed(body.decode("utf-8", errors="replace"))

        base = "https://" + self.server + base_path
        links = []
        for href in parser.links:
            full = urljoin(base, href)
            parsed = urlparse(full)
            # skip links that leave my domain (e.g. facebook.com)
            if parsed.netloc == self.server:
                path = parsed.path
                if parsed.query:
                    path = path + "?" + parsed.query
                links.append(path)
        return links, parser.flags

    def login(self):
        """
        Log in to Fakebook.
        1) GET the login page: the server give me a csrftoken cookie (parse_response stores it)
        and a csrfmiddlewaretoken hidden in the form.
        2) POST username, password and that token, with the cookie + Referer + Origin.
        """
        login_path = "/accounts/login/?next=/fakebook/"

        # 1) GET the login form, then pull the hidden token out of it
        status, headers, body = self.send(self.build_get(login_path))
        token = self.find_csrf_token(body)
        print("CSRF token from form: %s" % token)

        # 2) POST the form. all the fields go in the body, url-encoded.
        fields = {
            "username": self.username,
            "password": self.password,
            "csrfmiddlewaretoken": token,
            "next": "/fakebook/",
        }
        referer = "https://" + self.server + login_path
        status, headers, body = self.send(self.build_post(login_path, fields, referer))
        return status, headers

    def crawl(self):
        """
        BFS crawl from /fakebook/.
        frontier = a queue of paths still to visit;
        visited = a set of paths we already did (so we never loop
        on the same page).
        For each page: fetch it, parse it, save flags, and queue NEW links.
        We only follow paths that start with /fakebook/ --
        this skips the root "/" and, importantly, the /accounts/logout/ link.
        Stop the moment we have 5 flags.
        """
        frontier = deque(["/fakebook/"])
        visited = set(["/fakebook/"])
        flags = set()

        while frontier and len(flags) < 5:
            path = frontier.popleft()       # take the oldest path (FIFO = BFS)
            body = self.fetch(path)
            if body is None:
                continue                    # 403/404 dead end, skip it

            links, page_flags = self.parse_page(body, path)
            for flag in page_flags:
                if flag not in flags:
                    flags.add(flag)
                    print("found flag:", flag)    # show progress as we go

            for link in links:
                # only follow /fakebook/ pages we have NOT seen yet; this
                # skips "/" and the dangerous /accounts/logout/
                if link.startswith("/fakebook/") and link not in visited:
                    visited.add(link)
                    frontier.append(link)

        return flags

    def run(self):
        """
        Level 8: log in, then crawl the whole site (BFS) until we have
        all 5 secret flags, and print them.
        """
        self.login()
        flags = self.crawl()

        print("Done. Found %d flags:" % len(flags))
        for flag in flags:
            print(flag)

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='crawl Fakebook')
    parser.add_argument('-s', dest="server", type=str, default=DEFAULT_SERVER, help="The server to crawl")
    parser.add_argument('-p', dest="port", type=int, default=DEFAULT_PORT, help="The port to use")
    parser.add_argument('username', type=str, help="The username to use")
    parser.add_argument('password', type=str, help="The password to use")
    args = parser.parse_args()
    sender = Crawler(args)
    sender.run()
